# Rán backend — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# System prompt — two options, use one:
# Option A: paste the full prompt inline
IRPF_SYSTEM_PROMPT=paste-your-system-prompt-here

# Option B: path to a text file containing the prompt
# (useful when the prompt is long or managed separately)
# IRPF_SYSTEM_PROMPT_FILE=/path/to/prompt.txt

# The prompt is NOT committed to this repository.
# It lives in a private store (e.g. johanhellman/vanir) and is injected at runtime.

# Invite codes file — flat list of valid codes, one per line
# Used codes are prefixed with "USED:" automatically by the backend
INVITE_CODES_FILE=codes.txt

# Ops log — append-only JSONL file for operational metadata
# Contains: timestamp, file_size_bytes, code_used, returns_uploaded, response_time_ms
# Does NOT contain document content or user-identifying information
OPS_LOG_FILE=ops_log.jsonl
