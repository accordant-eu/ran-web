# Rán Web — environment variables
# Copy to .env and fill in values before running

# Anthropic API key — create a dedicated key for Rán at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# System prompt — path to the local prompt file.
# Fetch from the private repo before starting: ./scripts/fetch-prompt.sh
IRPF_SYSTEM_PROMPT_FILE=/srv/ran-web/prompts/irpf-reviewer-system-prompt.txt

# GitHub token for fetch-prompt.sh (rufus-vidar PAT, read access to accordant-eu/ran)
GITHUB_TOKEN=***

# Invite codes — one per line, format: CODE status (valid|used)
INVITE_CODES_FILE=/srv/ran-web/codes.txt

# Ops log — metadata only (timestamp, file size, code used, completion flag)
OPS_LOG_FILE=/srv/ran-web/ops_log.jsonl
MAX_CODE_USES=10                 # max uses per invite code (default 10)

# Model — default is claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
